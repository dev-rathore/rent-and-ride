<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All user</title>
</head>
<body>
    <table>
        <th>Name</th>
        <th>email</th>
        <th>role</th>
        <tbody>
            <% data.forEach((user) => { %>
            <tr>
                <td><%= user.username%>  </td>
                <td><%= user.email%>  </td>
                <td><%= user.role%>  </td>
                <td><button><a href='/dashboard/delete/user/<%=user._id%>'> Delete</a></button></td>   
                 
            </tr>
           
            <% }) %>
        </tbody>
    </table>
</body>
</html>